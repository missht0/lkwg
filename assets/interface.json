{
    "interface_version": 2,
    "name": "MaaLK",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA!",
    "github": "https://github.com/krendluck/lkwg",
    "version": "0.1.0",
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": ".*",
                "window_regex": "洛克王国：世界",
                "screencap": "FramePool",
                "mouse": "Seize",
                "keyboard": "Seize"
            }
        }
    ],
    "resource": [
        {
            "name": "桌面",
            "path": [
                "./resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "agent/main.py"
        ]
    },
    "task": [],
    "group": [
        {
            "name": "battle",
            "label": "战斗"
        },
        {
            "name": "daily",
            "label": "日常"
        },
        {
            "name": "demo",
            "label": "测试"
        }
    ],
    "option": {},
    "import": [
        "resource/tasks/focus_energy.json",
        "resource/tasks/auto_battle.json",
        "resource/tasks/battle_run.json",
        "resource/tasks/boss_battle.json",
        "resource/tasks/rare_beast.json",
        "resource/tasks/sunflower.json",
        "resource/tasks/clicker.json"
    ]
}
