{
    "task": [
    {
      "name": "战斗脱离",
      "entry": "Battle_RunEntry",
      "doc": "流程：识别战斗界面的 ESC/脱离入口 -> 按选择的方式点击脱离入口或按 ESC -> 点击确认 -> 根据配置只执行一次或继续循环检测。",
      "option": [
        "战斗脱离",
        "脱离方式"
            ],
            "group": ["demo"]
        }
    ],
    "option": {
        "战斗脱离": {
            "type": "select",
            "default_case": "只脱离一次",
            "cases": [
                {
                    "name": "只脱离一次",
                    "label": "只脱离一次",
                    "pipeline_override": {
                        "Confirm_Yes": {
                            "next": []
                        }
                    }
                },
                {
                    "name": "后台持续检测",
                    "label": "后台持续检测",
                    "pipeline_override": {
                        "Confirm_Yes": {
                            "next": [
                                "Battle_RunEntry"
                            ]
                        }
                    }
                }
            ]
        },
        "脱离方式": {
            "type": "select",
            "default_case": "点击脱离",
            "cases": [
                {
                    "name": "点击脱离",
                    "label": "点击脱离",
                    "pipeline_override": {
                        "Battle_RunEntry": {
                            "action": "Custom",
                            "custom_action": "InterceptionInput",
                            "custom_action_param": {
                                "type": "click_target"
                            }
                        }
                    }
                },
                {
                    "name": "按键 ESC",
                    "label": "按键 ESC",
                    "pipeline_override": {
                        "Battle_RunEntry": {
                            "action": "Custom",
                            "custom_action": "InterceptionInput",
                            "custom_action_param": {
                                "type": "click_key",
                                "key": 27
                            }
                        }
                    }
                }
            ]
        }
    }
}
