{
    "task": [
    {
      "name": "精灵首领",
      "entry": "BossBattle_Entry",
      "doc": "流程：重置技能状态 -> 等待战斗技能 1 可用 -> 普通阶段按技能顺序执行；检测到 z 时进入特殊阶段并按特殊技能顺序处理；战斗结束后可按住 W 进入奖励/宝藏区域，再按配置尝试使用印记。",
      "option": [
        "boss-技能顺序",
        "特殊阶段技能顺序",
                "boss-使用印记"
            ],
            "group": ["battle"]
        }
    ],
    "option": {
        "boss-技能顺序": {
            "type": "input",
            "inputs": [
                {
                    "name": "skill_order",
                    "label": "技能顺序 (1-4=技能, x=聚能, q=背包, r=关闭背包, |操作|次数 重复, |操作|a 无限循环)",
                    "default": "|1x|a",
                    "pipeline_type": "string",
                    "verify": "^[1-4xXqQrR|aA0-9]+$",
                    "pattern_msg": "只能包含 1-4, x(聚能), q(背包), r(关闭背包), |操作|次数(重复), |操作|a(无限循环)"
                }
            ],
            "pipeline_override": {
                "BossBattle_WaitSkill1": {
                    "attach": {
                        "skill_order": "{skill_order}"
                    }
                }
            }
        },
        "特殊阶段技能顺序": {
            "type": "input",
            "inputs": [
                {
                    "name": "special_skill_order",
                    "label": "特殊阶段技能顺序 (1-4=技能后按z确认, x=聚能, q=背包, r=关闭背包, |操作|次数, ||操作=无限循环)",
                    "default": "1",
                    "pipeline_type": "string",
                    "verify": "^[1-4xXqQrR|aA0-9]+$",
                    "pattern_msg": "只能包含 1-4, x(聚能), q(背包), r(关闭背包), |操作|次数(重复), |操作|a(无限循环)"
                }
            ],
            "pipeline_override": {
                "BossBattle_WaitSkill1": {
                    "attach": {
                        "special_skill_order": "{special_skill_order}"
                    }
                }
            }
        },
        "boss-使用印记": {
            "type": "select",
            "default_case": "不使用",
            "cases": [
                {
                    "name": "不使用",
                    "label": "不使用"
                },
                {
                    "name": "使用",
                    "label": "使用",
                    "pipeline_override": {
                        "BossBattle_UseMark": {
                            "attach": {
                                "use_mark": "true"
                            }
                        }
                    }
                }
            ]
        }
    }
}
