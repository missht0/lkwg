{
    "task": [
    {
      "name": "传说精灵",
      "entry": "AutoBattle_Entry",
      "doc": "流程：重置技能状态 -> 等待战斗技能 1 可用 -> 按配置的技能顺序执行一次技能/聚能/背包操作 -> 回到等待节点循环；如启用印记，会在战斗结束奖励界面尝试点击印记、确认并选择目标。",
      "option": [
        "使用印记",
        "技能顺序"
            ],
            "group": ["battle"]
        }
    ],
    "option": {
        "使用印记": {
            "type": "select",
            "default_case": "不使用",
            "cases": [
                {
                    "name": "不使用",
                    "label": "不使用"
                },
                {
                    "name": "使用",
                    "label": "使用",
                    "pipeline_override": {
                        "AutoBattle_UseMark": {
                            "attach": {
                                "use_mark": "true"
                            }
                        }
                    }
                }
            ]
        },
        "技能顺序": {
            "type": "input",
            "inputs": [
                {
                    "name": "skill_order",
                    "label": "技能顺序 (1-4=技能, x=聚能, q=背包, r=关闭背包, |操作|次数 重复, |操作|a 无限循环)",
                    "default": "|1x|a",
                    "pipeline_type": "string",
                    "verify": "^[1-4xXqQrR|aA0-9]+$",
                    "pattern_msg": "只能包含 1-4, x(聚能), q(背包), r(关闭背包), |操作|次数(重复), |操作|a(无限循环)"
                }
            ],
            "pipeline_override": {
                "AutoBattle_WaitReady": {
                    "attach": {
                        "skill_order": "{skill_order}"
                    }
                }
            }
        }
    }
}
