{
    "task": [
    {
      "name": "自动聚能",
      "entry": "Focus_EnergyEntry",
      "doc": "流程：等待并识别聚能图标 -> 命中后点击聚能图标或按 x 键 -> 根据配置只执行一次或回到入口后台持续检测。",
      "option": [
        "自动聚能",
        "聚能方式"
      ],
            "group": ["demo"]
        }
    ],
    "option": {
        "自动聚能": {
            "type": "select",
            "default_case": "后台持续检测",
            "cases": [
                {
                    "name": "只聚能一次",
                    "label": "只聚能一次",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "next": []
                        }
                    }
                },
                {
                    "name": "后台持续检测",
                    "label": "后台持续检测",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "next": [
                                "FocusEnergy_LoopWait"
                            ]
                        }
                    }
                }
            ]
        },
        "聚能方式": {
            "type": "select",
            "default_case": "点击方式",
            "cases": [
                {
                    "name": "按键 x",
                    "label": "按键 x",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "action": "Custom",
                            "custom_action": "InterceptionInput",
                            "custom_action_param": {
                                "type": "click_key",
                                "key": 88
                            }
                        }
                    }
                },
                {
                    "name": "点击方式",
                    "label": "点击方式",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "action": "Custom",
                            "custom_action": "InterceptionInput",
                            "custom_action_param": {
                                "type": "click_target"
                            }
                        }
                    }
                }
            ]
        }
    }
}
