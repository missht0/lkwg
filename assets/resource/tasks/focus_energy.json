{
    "task": [
    {
      "name": "自动聚能",
      "entry": "Focus_EnergyEntry",
      "doc": "流程：后台持续检测时每轮主动截图检查聚能图标，命中后点击聚能图标或按 x 键，未命中也继续轮询；只聚能一次时会等待图标出现，执行一次后结束。",
      "option": [
        "自动聚能",
        "聚能方式"
      ],
            "group": ["demo"]
        }
    ],
    "option": {
        "自动聚能": {
            "type": "select",
            "default_case": "后台持续检测",
            "cases": [
                {
                    "name": "只聚能一次",
                    "label": "只聚能一次",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "recognition": "TemplateMatch",
                            "template": "Battle/Energy.png",
                            "roi": [
                                11,
                                583,
                                102,
                                101
                            ],
                            "threshold": 0.7,
                            "action": "Custom",
                            "custom_action": "InterceptionInput",
                            "post_delay": 300,
                            "timeout": -1,
                            "next": []
                        }
                    }
                },
                {
                    "name": "后台持续检测",
                    "label": "后台持续检测",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "recognition": "DirectHit",
                            "action": "Custom",
                            "custom_action": "FocusEnergyPollAct",
                            "post_delay": 1000,
                            "next": [
                                "FocusEnergy_LoopWait"
                            ]
                        }
                    }
                }
            ]
        },
        "聚能方式": {
            "type": "select",
            "default_case": "点击方式",
            "cases": [
                {
                    "name": "按键 x",
                    "label": "按键 x",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "custom_action_param": {
                                "type": "click_key",
                                "key": 88
                            }
                        }
                    }
                },
                {
                    "name": "点击方式",
                    "label": "点击方式",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "custom_action_param": {
                                "type": "click_target"
                            }
                        }
                    }
                }
            ]
        }
    }
}
